---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Fixing the world piece by piece. Free tools, open source, built to share.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={Astro.url.href}>
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <div class="site-bg"></div>
  <div class="site-bg site-bg-2"></div>

  <!-- Spiral nav trigger — top right -->
  <div class="spiral-trigger" id="spiral-trigger">
    <button type="button" class="spiral-btn" id="spiral-btn" aria-label="Menu" aria-expanded="false">
      <svg class="spiral-icon" viewBox="0 0 32 32" fill="none">
        <path d="M16 4 C22 4 28 10 28 16 C28 22 22 28 16 28 C12 28 8 24 8 20 C8 16 12 12 16 12 C18 12 20 14 20 16 C20 18 18 20 16 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
      </svg>
    </button>
  </div>

  <!-- Spiral menu overlay -->
  <div class="spiral-menu" id="spiral-menu" hidden>
    <div class="spiral-glass" id="spiral-backdrop"></div>
    <canvas class="spiral-galaxy" id="spiral-galaxy"></canvas>
    <div class="warp-flash" id="warp-flash"></div>

    <!-- Level 0: Main star map -->
    <nav class="spiral-nav spiral-nav-0" id="nav-0" aria-label="Navigation">
      <a href="/" class="spiral-item" style="--i:0; --sx:50%; --sy:24%;"><span class="star-dot"></span>Home</a>
      <button type="button" class="spiral-item constellation-trigger" data-target="nav-blocks" style="--i:1; --sx:72%; --sy:40%;"><span class="star-dot sd-gold"></span>Blocks<span class="constellation-hint">constellation</span></button>
      <a href="/blocks/golden-voice" class="spiral-item" style="--i:2; --sx:35%; --sy:52%;"><span class="star-dot"></span>golden-voice</a>
      <a href="https://github.com/goldenfocus/golden-cloud" target="_blank" class="spiral-item" style="--i:3; --sx:60%; --sy:72%;"><span class="star-dot"></span>Golden Cloud</a>
      <button type="button" class="spiral-item constellation-trigger" data-target="nav-github" style="--i:4; --sx:25%; --sy:36%;"><span class="star-dot sd-silver"></span>GitHub<span class="constellation-hint">constellation</span></button>
    </nav>

    <!-- Level 1: Blocks constellation -->
    <nav class="spiral-nav spiral-nav-sub" id="nav-blocks" hidden aria-label="Blocks">
      <button type="button" class="spiral-item spiral-back" data-target="nav-0" style="--i:0; --sx:15%; --sy:12%;"><span class="star-dot sd-dim"></span>← back</button>
      <a href="/blocks" class="spiral-item" style="--i:1; --sx:45%; --sy:30%;"><span class="star-dot sd-gold"></span>All Blocks</a>
      <a href="/blocks/golden-voice" class="spiral-item" style="--i:2; --sx:62%; --sy:50%;"><span class="star-dot sd-gold"></span>golden-voice</a>
    </nav>

    <!-- Level 1: GitHub constellation -->
    <nav class="spiral-nav spiral-nav-sub" id="nav-github" hidden aria-label="GitHub">
      <button type="button" class="spiral-item spiral-back" data-target="nav-0" style="--i:0; --sx:15%; --sy:12%;"><span class="star-dot sd-dim"></span>← back</button>
      <a href="https://github.com/goldenfocus" target="_blank" class="spiral-item" style="--i:1; --sx:50%; --sy:35%;"><span class="star-dot sd-silver"></span>goldenfocus</a>
      <a href="https://github.com/goldenfocus/golden-cloud" target="_blank" class="spiral-item" style="--i:2; --sx:65%; --sy:55%;"><span class="star-dot sd-silver"></span>golden-cloud</a>
    </nav>
  </div>

  <script is:inline>
    (function () {
      var btn = document.getElementById('spiral-btn');
      var menu = document.getElementById('spiral-menu');
      var backdrop = document.getElementById('spiral-backdrop');
      var canvas = document.getElementById('spiral-galaxy');
      var flash = document.getElementById('warp-flash');
      if (!btn || !menu || !canvas) return;
      var ctx = canvas.getContext('2d');
      var raf = 0, stars = [], dpr = window.devicePixelRatio || 1;
      var W, H, t = 0;
      var warp = 'none';
      var warpT = 0;
      var WARP_DUR = 50;
      var activeNav = 'nav-0';

      var WARM = [[251,191,36],[245,158,11],[252,211,77],[217,119,6],[254,243,199]];
      var COOL = [[220,230,255],[200,210,240],[180,195,225],[240,245,255]];
      var MAX_Z = 6, FOCAL = 340, COUNT = 180;

      function resize() {
        W = window.innerWidth; H = window.innerHeight;
        canvas.width = W * dpr; canvas.height = H * dpr;
        canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function mkStar(scatter) {
        var silver = Math.random() < 0.3;
        var pal = silver ? COOL : WARM;
        var c = pal[Math.floor(Math.random() * pal.length)];
        return {
          x: (Math.random() - 0.5) * 2.6, y: (Math.random() - 0.5) * 2.6,
          z: scatter ? Math.random() * MAX_Z + 0.2 : MAX_Z + Math.random() * 2,
          c: c, baseR: 0.3 + Math.random() * 1.5,
          speed: 0.001 + Math.random() * 0.0018,
          ts: 0.004 + Math.random() * 0.018, tp: Math.random() * 6.28,
        };
      }

      function init() {
        stars = [];
        for (var i = 0; i < COUNT; i++) stars.push(mkStar(true));
      }

      function draw() {
        t++;
        ctx.clearRect(0, 0, W, H);
        var cx = W * 0.5, cy = H * 0.5;
        var isWarping = warp === 'forward' || warp === 'reverse';
        var warpProgress = 0;
        if (isWarping) {
          warpT++;
          warpProgress = Math.min(warpT / WARP_DUR, 1);
        }
        var speedMult = isWarping ? 1 + warpProgress * 80 : 1;

        for (var i = 0; i < stars.length; i++) {
          var s = stars[i];
          s.z -= s.speed * speedMult;
          if (s.z < 0.06) { stars[i] = mkStar(false); continue; }

          var invZ = 1 / s.z;
          var sx = cx + s.x * FOCAL * invZ;
          var sy = cy + s.y * FOCAL * invZ;
          if (sx < -200 || sx > W + 200 || sy < -200 || sy > H + 200) { stars[i] = mkStar(false); continue; }

          var r = s.baseR * invZ * 2.5;
          if (r > 5) r = 5;
          var tw = Math.sin(t * s.ts + s.tp);
          var depthA = Math.min(invZ * 1.1, 1);
          var al = depthA * (0.35 + 0.65 * tw);
          var col = 'rgba(' + s.c[0] + ',' + s.c[1] + ',' + s.c[2] + ',';

          if (isWarping && r > 0.3) {
            var dx = sx - cx, dy = sy - cy;
            var dist = Math.sqrt(dx * dx + dy * dy) || 1;
            var nx = dx / dist, ny = dy / dist;
            var streakLen = r * (5 + warpProgress * 60);
            var endX = sx + nx * streakLen;
            var endY = sy + ny * streakLen;
            var sg = ctx.createLinearGradient(endX, endY, sx, sy);
            sg.addColorStop(0, col + (al * 0.9) + ')');
            sg.addColorStop(1, col + '0)');
            ctx.save();
            ctx.lineCap = 'round';
            ctx.strokeStyle = sg;
            ctx.lineWidth = Math.max(r * 0.6, 0.5);
            ctx.shadowColor = col + (al * 0.3) + ')';
            ctx.shadowBlur = 6;
            ctx.beginPath(); ctx.moveTo(sx, sy); ctx.lineTo(endX, endY);
            ctx.stroke(); ctx.restore();
          }

          if (!isWarping) {
            if (r < 1.0 && al > 0.5) {
              ctx.save();
              ctx.globalAlpha = al * 0.4;
              ctx.strokeStyle = col + '0.3)';
              ctx.lineWidth = 0.4;
              var rl = r * 5;
              ctx.beginPath();
              ctx.moveTo(sx - rl, sy); ctx.lineTo(sx + rl, sy);
              ctx.moveTo(sx, sy - rl); ctx.lineTo(sx, sy + rl);
              ctx.stroke(); ctx.restore();
            }
            if (r > 0.8 && r < 1.5) {
              ctx.shadowColor = col + (al * 0.3) + ')';
              ctx.shadowBlur = 4;
            } else { ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0; }
          } else {
            ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0;
          }

          ctx.beginPath();
          ctx.arc(sx, sy, Math.max(r, 0.2), 0, 6.28);
          ctx.fillStyle = col + al + ')';
          ctx.fill();
        }

        ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0;

        if (isWarping && warpT >= WARP_DUR) {
          if (warp === 'forward') triggerFlash(pendingTarget);
          else if (warp === 'reverse') triggerFlash(pendingTarget);
        }

        raf = requestAnimationFrame(draw);
      }

      var pendingTarget = null;

      function startWarp(direction, targetId) {
        warp = direction;
        warpT = 0;
        pendingTarget = targetId;
        var currentNav = document.getElementById(activeNav);
        if (currentNav) {
          currentNav.classList.remove('nav-visible');
          currentNav.classList.add('nav-fading');
        }
      }

      function triggerFlash(targetId) {
        warp = 'none';
        flash.classList.add('flash-active');
        setTimeout(function () {
          switchNav(targetId);
          flash.classList.remove('flash-active');
        }, 250);
      }

      function switchNav(targetId) {
        document.querySelectorAll('.spiral-nav').forEach(function (n) {
          n.hidden = true;
          n.classList.remove('nav-visible', 'nav-fading');
        });
        var target = document.getElementById(targetId);
        if (target) {
          target.hidden = false;
          activeNav = targetId;
          requestAnimationFrame(function () { target.classList.add('nav-visible'); });
        }
      }

      menu.addEventListener('click', function (e) {
        var trigger = e.target.closest('.constellation-trigger');
        if (trigger) {
          e.preventDefault();
          startWarp('forward', trigger.dataset.target);
          return;
        }
        var back = e.target.closest('.spiral-back');
        if (back) {
          e.preventDefault();
          startWarp('reverse', back.dataset.target);
          return;
        }
        var link = e.target.closest('a.spiral-item');
        if (link) close();
      });

      function open() {
        menu.hidden = false;
        btn.setAttribute('aria-expanded', 'true');
        document.body.classList.add('spiral-active');
        resize(); init(); warp = 'none';
        switchNav('nav-0');
        raf = requestAnimationFrame(draw);
        requestAnimationFrame(function () {
          menu.classList.add('is-open');
          document.getElementById('nav-0').classList.add('nav-visible');
        });
      }
      function close() {
        menu.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('spiral-active');
        cancelAnimationFrame(raf);
        document.querySelectorAll('.spiral-nav').forEach(function (n) {
          n.classList.remove('nav-visible', 'nav-fading');
        });
        setTimeout(function () { menu.hidden = true; }, 500);
      }
      btn.addEventListener('click', function () { menu.hidden ? open() : close(); });
      backdrop.addEventListener('click', close);
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !menu.hidden) close(); });
      window.addEventListener('resize', function () { if (!menu.hidden) resize(); });
    })();
  </script>

  <!-- Minimal brand mark — bottom left, barely there -->
  <a href="/" class="brand-mark">
    <span class="gold-text">GF</span>
  </a>

  <main>
    <slot />
  </main>

  <footer>
    <div class="container footer-inner">
      <div class="footer-gold-line"></div>
      <p class="gold-text footer-brand">GoldenFocus</p>
      <p class="footer-tagline">fixing the world piece by piece</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  /* ── Spiral trigger ────────────────────────── */
  .spiral-trigger {
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 100;
  }
  .spiral-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    outline: none;
    cursor: pointer;
    color: var(--text-muted);
    transition: color 0.4s, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spiral-btn:hover,
  .spiral-btn[aria-expanded="true"] {
    color: var(--gold-400);
    transform: rotate(180deg);
    filter: drop-shadow(0 0 6px rgba(251,191,36,0.3));
  }
  .spiral-btn:focus-visible {
    outline: none;
  }
  .spiral-icon {
    width: 28px;
    height: 28px;
  }

  /* ── Brand mark ────────────────────────────── */
  .brand-mark {
    position: fixed;
    top: 28px;
    left: 28px;
    z-index: 100;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.5px;
    opacity: 0.3;
    transition: opacity 0.3s;
  }
  .brand-mark:hover { opacity: 1; }

  /* ── Body fade when menu is active ─────────── */
  :global(body.spiral-active) {
    overflow: hidden;
  }
  :global(body.spiral-active) main,
  :global(body.spiral-active) footer,
  :global(body.spiral-active) .brand-mark {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease-out;
  }
  main, footer, .brand-mark {
    transition: opacity 0.4s ease-in;
  }

  /* ── Spiral menu ───────────────────────────── */
  .spiral-menu {
    position: fixed;
    inset: 0;
    z-index: 99;
  }

  .site-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: url('/hero.png') center 40% / cover no-repeat;
    background-color: var(--ink-900);
    transform-origin: 28% 45%;
    animation: drift-into-sun 3600s linear forwards;
  }
  .site-bg-2 {
    background:
      radial-gradient(ellipse at 65% 40%, rgba(90,60,160,0.4) 0%, transparent 50%),
      radial-gradient(ellipse at 30% 60%, rgba(40,80,180,0.3) 0%, transparent 45%),
      radial-gradient(ellipse at 50% 30%, rgba(120,80,200,0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 70%, rgba(60,40,120,0.25) 0%, transparent 40%),
      var(--ink-900);
    transform-origin: 60% 45%;
    opacity: 0;
    animation:
      galaxy-2-in 3600s 1800s linear forwards,
      drift-into-sun 3600s 1800s linear forwards;
  }
  @keyframes drift-into-sun {
    from { transform: scale(1); }
    to { transform: scale(3); }
  }
  @keyframes galaxy-2-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .spiral-glass {
    position: absolute;
    inset: 0;
  }

  .warp-flash {
    position: absolute;
    inset: 0;
    z-index: 10;
    background: radial-gradient(circle at center, rgba(255,250,240,0.9) 0%, rgba(251,191,36,0.3) 40%, transparent 70%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
  }
  .warp-flash.flash-active {
    opacity: 1;
    transition: opacity 0.08s;
  }

  .spiral-galaxy {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.8s ease-out 0.1s;
  }
  .spiral-menu.is-open .spiral-galaxy { opacity: 1; }

  .spiral-nav {
    position: absolute;
    inset: 0;
    z-index: 2;
  }
  .spiral-item {
    position: absolute;
    left: var(--sx);
    top: var(--sy);
    transform: translate(-50%, -50%) scale(0.5);
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 2px;
    color: rgba(245,245,247,0.55);
    white-space: nowrap;
    text-transform: lowercase;
    opacity: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 4px;
    transition:
      opacity 0.6s calc(var(--i) * 0.12s) ease-out,
      transform 0.8s calc(var(--i) * 0.12s) cubic-bezier(0.16, 1, 0.3, 1),
      color 0.3s,
      text-shadow 0.3s;
    text-shadow: 0 0 0 transparent;
  }
  .nav-visible .spiral-item {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    text-shadow: 0 0 24px rgba(245,158,11,0.15);
  }
  .nav-fading .spiral-item {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.3);
    transition: opacity 0.3s, transform 0.3s;
  }
  .spiral-item:hover {
    color: var(--gold-300);
    text-shadow: 0 0 30px rgba(251,191,36,0.5), 0 0 80px rgba(245,158,11,0.2);
  }
  .spiral-item:hover .star-dot {
    background: var(--gold-400);
    box-shadow: 0 0 10px var(--gold-400), 0 0 30px rgba(251,191,36,0.5);
    width: 8px; height: 8px;
  }

  .constellation-hint {
    display: block;
    font-size: 9px;
    letter-spacing: 3px;
    color: rgba(245,245,247,0.2);
    margin-top: 2px;
    margin-left: 18px;
  }

  .star-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(245,245,247,0.6);
    margin-right: 12px;
    vertical-align: middle;
    box-shadow: 0 0 6px rgba(245,245,247,0.3), 0 0 16px rgba(251,191,36,0.15);
    transition: all 0.3s;
  }
  .sd-gold {
    background: var(--gold-400);
    box-shadow: 0 0 6px var(--gold-500), 0 0 16px rgba(251,191,36,0.3);
  }
  .sd-silver {
    background: rgba(200,210,240,0.7);
    box-shadow: 0 0 6px rgba(200,210,240,0.4), 0 0 16px rgba(180,195,225,0.2);
  }
  .sd-dim {
    background: rgba(245,245,247,0.3);
    box-shadow: none;
  }
  .spiral-back {
    font-size: 12px;
    letter-spacing: 1px;
    color: rgba(245,245,247,0.35);
  }
  .spiral-back:hover { color: rgba(245,245,247,0.7); }

  /* ── Footer ────────────────────────────────── */
  footer {
    margin-top: 100px;
    padding: 40px 0 32px;
    text-align: center;
  }
  .footer-inner { position: relative; }
  .footer-gold-line {
    width: 60px;
    height: 1px;
    margin: 0 auto 20px;
    background: linear-gradient(90deg, transparent, var(--gold-500), transparent);
  }
  .footer-brand {
    font-size: 18px;
    font-weight: 700;
  }
  .footer-tagline {
    margin-top: 4px;
    font-size: 12px;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 1px;
  }
</style>
